# Copy to .env and fill in. .env is gitignored.

# Server (optional)
# PORT=3001

# OpenAI — chat replies are polished when set; test with GET /api/health/openai
# OPENAI_API_KEY=sk-...
# Optional (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Add any other provider keys the same way:
# ANTHROPIC_API_KEY=
# TELEGRAM_BOT_TOKEN=
